# Audora Music Player — Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# YouTube Data API v3 key (optional — needed for YouTube video/search features)
# Server-side only — never exposed to the browser bundle
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# OpenRouter API key (optional — needed for AI Song Insights)
# Server-side only — never exposed to the browser bundle
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# OpenRouter model (optional — defaults to google/gemini-2.0-flash-001)
# See available models at: https://openrouter.ai/models
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Spotify API credentials (optional — needed for Artist Info & Song Popularity)
# Server-side only — never exposed to the browser bundle
# Get yours at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# DAB Music API credentials (optional — needed for online music search & download)
# Server-side only — never exposed to the browser bundle
# Sign up at: https://dabmusic.xyz
DAB_EMAIL=
DAB_PASSWORD=

# Node environment (automatically set by Next.js)
# NODE_ENV=development
